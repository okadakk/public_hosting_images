[
  {% if items.size >= 1 %}
    { "type": "text", "text": "{{ headerLabel }}" },
  {% else %}
    { "type": "text", "text": "条件に合う物件が見つかりませんでした。条件を変えてお試しください。" },
  {% endif %}
  {
    "type": "carousel",
    "contents": [
      {% for item in items %}{
        "type": "bubble",
        "size": "kilo",
        "hero": {% if item.recommendImageUrl %}{ "type": "image", "url": "{{ item.recommendImageUrl }}", "size": "full", "aspectRatio": "1:1", "aspectMode": "cover" }{% else %}{ "type": "box", "layout": "vertical", "backgroundColor": "{{ colors.primary }}", "height": "220px", "justifyContent": "center", "alignItems": "center", "contents": [{ "type": "text", "text": "No Image", "color": "#ffffff80", "size": "xxs", "align": "center" }] }{% endif %},
        "body": {
          "type": "box",
          "layout": "vertical",
          "spacing": "sm",
          "paddingAll": "14px",
          "contents": [
            { "type": "text", "text": "{{ item.recommendTitle }}", "weight": "bold", "size": "lg", "wrap": true, "maxLines": 2, "color": "{{ colors.textPrimary }}" },
            {% if item.recommendDescription1 %}{ "type": "text", "text": "{{ item.recommendDescription1 }}", "size": "xs", "color": "{{ colors.primary }}" },{% endif %}
            {% if item.recommendDescription2 %}{ "type": "text", "text": "{{ item.recommendDescription2 }}", "size": "xs", "color": "#666666", "wrap": true, "maxLines": 2 },{% endif %}
            {% if item.recommendDescription3 %}{ "type": "text", "text": "¥{{ item.recommendDescription3 }}", "weight": "bold", "size": "xl", "color": "{{ colors.textPrimary }}" },{% endif %}
            {% if item.recommendDescription4 or item.recommendDescription5 %}{
              "type": "box",
              "layout": "horizontal",
              "spacing": "sm",
              "contents": [
                {% assign metaPrinted = false %}
                {% if item.recommendDescription4 %}{ "type": "text", "text": "利回り {{ item.recommendDescription4 }}%", "size": "sm", "color": "{{ colors.primary }}", "flex": 0 }{% assign metaPrinted = true %}{% endif %}
                {% if item.recommendDescription5 %}{% if metaPrinted %},{% endif %}{ "type": "text", "text": "{{ item.recommendDescription5 }}BR", "size": "sm", "color": "#888888", "flex": 0 }{% endif %}
              ]
            },{% endif %}
            {% if item.recommendDescription6 %}{ "type": "text", "text": "建物 {{ item.recommendDescription6 }}m²{% if item.recommendDescription7 %} / 土地 {{ item.recommendDescription7 }}m²{% else %} / 土地 -{% endif %}", "size": "xs", "color": "#666666", "wrap": true, "maxLines": 1 },{% endif %}
            {% if item.recommendDescription8 %}{ "type": "text", "text": "{{ item.recommendDescription8 }}", "size": "xs", "color": "#888888", "wrap": true, "maxLines": 2 }{% else %}{ "type": "box", "layout": "vertical", "contents": [], "height": "1px" }{% endif %}
          ]
        },
        "footer": {
          "type": "box",
          "layout": "vertical",
          "paddingAll": "12px",
          "contents": [
            { "type": "button", "action": { "type": "postback", "label": "相談する", "data": "{{ item.postbackData }}", "displayText": "{{ item.recommendTitle }}" }, "style": "primary", "color": "{{ colors.primary }}", "height": "sm" }
          ]
        }
      }{% unless forloop.last %},{% endunless %}{% endfor %}
      {% if items.size <= 2 %}
        {% if items.size > 0 %},{% endif %}
        {
          "type": "bubble",
          "size": "kilo",
          "hero": {
            "type": "box",
            "layout": "vertical",
            "backgroundColor": "{{ colors.background }}",
            "height": "220px",
            "contents": []
          },
          "body": {
            "type": "box",
            "layout": "vertical",
            "spacing": "sm",
            "paddingAll": "12px",
            "contents": [
              { "type": "text", "text": "別条件の物件も探せます", "weight": "bold", "size": "sm", "wrap": true, "maxLines": 2 },
              { "type": "text", "text": "予算・エリア・利回りなど条件を変えて、別の候補もご案内できます。", "size": "xs", "color": "#6B7280", "wrap": true, "maxLines": 3 }
            ]
          },
          "footer": {
            "type": "box",
            "layout": "vertical",
            "paddingAll": "12px",
            "contents": [
              {
                "type": "button",
                "action": {
                  "type": "message",
                  "label": "条件を見直す",
                  "text": "条件を見直したい"
                },
                "style": "secondary",
                "height": "sm"
              }
            ]
          }
        }
      {% endif %}
    ]
  }
]