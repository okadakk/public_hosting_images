[
  { "type": "text", "text": "{{ headerLabel | default: 'ご希望の時間を選択してください。' }}" },
  {
    "type": "bubble",
    "size": "giga",
    "header": {
      "type": "box",
      "layout": "vertical",
      "backgroundColor": "#1B6CE0",
      "paddingAll": "12px",
      "contents": [
        { "type": "text", "text": "{{ selectedDate | format_date }}", "color": "#ffffff", "weight": "bold", "size": "lg", "wrap": true },
        { "type": "text", "text": "{{ headerLabel }}", "color": "#ffffff", "size": "xs", "margin": "sm", "wrap": true }
      ]
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "spacing": "md",
      "backgroundColor": "#F9FAFB",
      "paddingAll": "12px",
      "contents": [
        {% if amRows.size > 0 %}
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              { "type": "text", "text": "午前", "size": "sm", "weight": "bold", "color": "#111111", "flex": 1 },
              { "type": "text", "text": "{{ amSlots.size }}枠", "size": "xs", "color": "#888888", "align": "end" }
            ]
          }
          {% for row in amRows %},{
            "type": "box",
            "layout": "horizontal",
            "spacing": "sm",
            "margin": "sm",
            "contents": [
              {% for s in row %}{
                "type": "box",
                "layout": "vertical",
                "flex": 1,
                "margin": "4px",
                "backgroundColor": "#DDEBFF",
                "cornerRadius": "10px",
                "paddingBottom": "4px",
                "paddingTop": "0px",
                "paddingStart": "0px",
                "paddingEnd": "0px",
                "action": { "type": "postback", "label": "{{ s.label }}", "data": "{{ s.postbackData }}", "displayText": "{{ s.label }}" },
                "contents": [
                  {
                    "type": "box",
                    "layout": "vertical",
                    "backgroundColor": "#1B6CE0",
                    "cornerRadius": "10px",
                    "paddingTop": "10px",
                    "paddingBottom": "10px",
                    "paddingStart": "4px",
                    "paddingEnd": "4px",
                    "contents": [
                      { "type": "text", "text": "{{ s.label }}", "color": "#ffffff", "weight": "bold", "size": "sm", "align": "center" }
                    ]
                  }
                ]
              }{% unless forloop.last %},{% endunless %}{% endfor %}
              {% assign fillers = 4 | minus: row.size %}{% for i in (1..fillers) %},{ "type": "filler" }{% endfor %}
            ]
          }{% endfor %}
        {% endif %}
        {% if amRows.size > 0 and pmRows.size > 0 %},{ "type": "separator", "margin": "md", "color": "#E5E7EB" }{% endif %}
        {% if pmRows.size > 0 %}
          {% if amRows.size > 0 %},{% endif %}
          {
            "type": "box",
            "layout": "horizontal",
            {% if amRows.size > 0 %}"margin": "md",{% endif %}
            "contents": [
              { "type": "text", "text": "午後", "size": "sm", "weight": "bold", "color": "#111111", "flex": 1 },
              { "type": "text", "text": "{{ pmSlots.size }}枠", "size": "xs", "color": "#888888", "align": "end" }
            ]
          }
          {% for row in pmRows %},{
            "type": "box",
            "layout": "horizontal",
            "spacing": "sm",
            "margin": "sm",
            "contents": [
              {% for s in row %}{
                "type": "box",
                "layout": "vertical",
                "flex": 1,
                "margin": "4px",
                "backgroundColor": "#DDEBFF",
                "cornerRadius": "10px",
                "paddingBottom": "4px",
                "paddingTop": "0px",
                "paddingStart": "0px",
                "paddingEnd": "0px",
                "action": { "type": "postback", "label": "{{ s.label }}", "data": "{{ s.postbackData }}", "displayText": "{{ s.label }}" },
                "contents": [
                  {
                    "type": "box",
                    "layout": "vertical",
                    "backgroundColor": "#1B6CE0",
                    "cornerRadius": "10px",
                    "paddingTop": "10px",
                    "paddingBottom": "10px",
                    "paddingStart": "4px",
                    "paddingEnd": "4px",
                    "contents": [
                      { "type": "text", "text": "{{ s.label }}", "color": "#ffffff", "weight": "bold", "size": "sm", "align": "center" }
                    ]
                  }
                ]
              }{% unless forloop.last %},{% endunless %}{% endfor %}
              {% assign fillers = 4 | minus: row.size %}{% for i in (1..fillers) %},{ "type": "filler" }{% endfor %}
            ]
          }{% endfor %}
        {% endif %}
      ]
    }
  }
]