[
  { "type": "text", "text": "{{ headerLabel | default: 'ご希望の日付を選択してください。' }}" },
  {% if months.size == 1 %}
    {% assign m = months[0] %}
    {
      "type": "bubble",
      "size": "giga",
      "header": {
        "type": "box",
        "layout": "vertical",
        "backgroundColor": "#1B6CE0",
        "paddingAll": "8px",
        "contents": [
          { "type": "text", "text": "{{ headerLabel }}", "color": "#ffffff", "weight": "bold", "size": "md", "align": "center", "wrap": true }
        ]
      },
      "body": {
        "type": "box",
        "layout": "vertical",
        "spacing": "none",
        "backgroundColor": "#F9FAFB",
        "paddingStart": "8px",
        "paddingEnd": "8px",
        "paddingTop": "0px",
        "paddingBottom": "16px",
        "contents": [
          {
            "type": "box",
            "layout": "horizontal",
            "paddingStart": "8px",
            "paddingEnd": "8px",
            "alignItems": "center",
            "contents": [
              { "type": "text", "text": "{{ m.year }}", "size": "lg", "weight": "bold", "color": "#1B6CE0", "flex": 0 },
              { "type": "text", "text": "{{ m.month }}", "size": "5xl", "weight": "bold", "color": "#1B6CE0", "flex": 0, "margin": "md" }
            ]
          },
          {
            "type": "box",
            "layout": "vertical",
            "paddingTop": "0px",
            "spacing": "none",
            "paddingAll": "0px",
            "contents": [
              {
                "type": "box",
                "layout": "horizontal",
                "contents": [
                  { "type": "text", "text": "日", "color": "#D95C5C", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                  { "type": "text", "text": "月", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                  { "type": "text", "text": "火", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                  { "type": "text", "text": "水", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                  { "type": "text", "text": "木", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                  { "type": "text", "text": "金", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                  { "type": "text", "text": "土", "color": "#1B6CE0", "align": "center", "size": "sm", "weight": "bold", "flex": 1 }
                ]
              }
              {% for week in m.weeks %},{
                "type": "box",
                "layout": "horizontal",
                "margin": "4px",
                "contents": [
                  {% for cell in week %}{% if cell.available %}{
                    "type": "box",
                    "layout": "vertical",
                    "flex": 1,
                    "margin": "3px",
                    "backgroundColor": "#DDEBFF",
                    "cornerRadius": "10px",
                    "paddingBottom": "4px",
                    "paddingTop": "0px",
                    "paddingStart": "0px",
                    "paddingEnd": "0px",
                    "action": { "type": "postback", "label": "{{ cell.day }}", "data": "{{ cell.postbackData }}", "displayText": "{{ cell.day }}" },
                    "contents": [
                      {
                        "type": "box",
                        "layout": "vertical",
                        "backgroundColor": "#1B6CE0",
                        "cornerRadius": "10px",
                        "paddingTop": "4px",
                        "paddingBottom": "4px",
                        "paddingStart": "4px",
                        "paddingEnd": "4px",
                        "contents": [
                          { "type": "text", "text": "{{ cell.day }}", "color": "#ffffff", "weight": "bold", "size": "xl", "align": "center" }
                        ]
                      }
                    ]
                  }{% elsif cell.day %}{
                    "type": "box",
                    "layout": "vertical",
                    "flex": 1,
                    "margin": "3px",
                    "backgroundColor": "#E5E7EB",
                    "cornerRadius": "10px",
                    "paddingBottom": "4px",
                    "paddingTop": "0px",
                    "paddingStart": "0px",
                    "paddingEnd": "0px",
                    "contents": [
                      {
                        "type": "box",
                        "layout": "vertical",
                        "backgroundColor": "#C9D0DB",
                        "cornerRadius": "10px",
                        "paddingTop": "4px",
                        "paddingBottom": "4px",
                        "paddingStart": "4px",
                        "paddingEnd": "4px",
                        "contents": [
                          { "type": "text", "text": "{{ cell.day }}", "color": "#ffffff", "weight": "bold", "size": "xl", "align": "center" }
                        ]
                      }
                    ]
                  }{% else %}{ "type": "box", "layout": "vertical", "flex": 1, "contents": [], "margin": "3px" }{% endif %}{% unless forloop.last %},{% endunless %}{% endfor %}
                ]
              }{% endfor %}
            ]
          }
        ]
      }
    }
  {% else %}
    {
      "type": "carousel",
      "contents": [
        {% for m in months %}{
          "type": "bubble",
          "size": "giga",
          "header": {
            "type": "box",
            "layout": "vertical",
            "backgroundColor": "#1B6CE0",
            "paddingAll": "8px",
            "contents": [
              { "type": "text", "text": "{{ headerLabel }}", "color": "#ffffff", "weight": "bold", "size": "md", "align": "center", "wrap": true }
            ]
          },
          "body": {
            "type": "box",
            "layout": "vertical",
            "spacing": "none",
            "backgroundColor": "#F9FAFB",
            "paddingStart": "8px",
            "paddingEnd": "8px",
            "paddingTop": "0px",
            "paddingBottom": "16px",
            "contents": [
              {
                "type": "box",
                "layout": "horizontal",
                "paddingStart": "8px",
                "paddingEnd": "8px",
                "alignItems": "center",
                "contents": [
                  { "type": "text", "text": "{{ m.year }}", "size": "lg", "weight": "bold", "color": "#1B6CE0", "flex": 0 },
                  { "type": "text", "text": "{{ m.month }}", "size": "5xl", "weight": "bold", "color": "#1B6CE0", "flex": 0, "margin": "md" }
                ]
              },
              {
                "type": "box",
                "layout": "vertical",
                "paddingTop": "0px",
                "spacing": "none",
                "paddingAll": "0px",
                "contents": [
                  {
                    "type": "box",
                    "layout": "horizontal",
                    "contents": [
                      { "type": "text", "text": "日", "color": "#D95C5C", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                      { "type": "text", "text": "月", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                      { "type": "text", "text": "火", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                      { "type": "text", "text": "水", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                      { "type": "text", "text": "木", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                      { "type": "text", "text": "金", "color": "#333333", "align": "center", "size": "sm", "weight": "bold", "flex": 1 },
                      { "type": "text", "text": "土", "color": "#1B6CE0", "align": "center", "size": "sm", "weight": "bold", "flex": 1 }
                    ]
                  }
                  {% for week in m.weeks %},{
                    "type": "box",
                    "layout": "horizontal",
                    "margin": "4px",
                    "contents": [
                      {% for cell in week %}{% if cell.available %}{
                        "type": "box",
                        "layout": "vertical",
                        "flex": 1,
                        "margin": "3px",
                        "backgroundColor": "#DDEBFF",
                        "cornerRadius": "10px",
                        "paddingBottom": "4px",
                        "paddingTop": "0px",
                        "paddingStart": "0px",
                        "paddingEnd": "0px",
                        "action": { "type": "postback", "label": "{{ cell.day }}", "data": "{{ cell.postbackData }}", "displayText": "{{ cell.day }}" },
                        "contents": [
                          {
                            "type": "box",
                            "layout": "vertical",
                            "backgroundColor": "#1B6CE0",
                            "cornerRadius": "10px",
                            "paddingTop": "4px",
                            "paddingBottom": "4px",
                            "paddingStart": "4px",
                            "paddingEnd": "4px",
                            "contents": [
                              { "type": "text", "text": "{{ cell.day }}", "color": "#ffffff", "weight": "bold", "size": "xl", "align": "center" }
                            ]
                          }
                        ]
                      }{% elsif cell.day %}{
                        "type": "box",
                        "layout": "vertical",
                        "flex": 1,
                        "margin": "3px",
                        "backgroundColor": "#E5E7EB",
                        "cornerRadius": "10px",
                        "paddingBottom": "4px",
                        "paddingTop": "0px",
                        "paddingStart": "0px",
                        "paddingEnd": "0px",
                        "contents": [
                          {
                            "type": "box",
                            "layout": "vertical",
                            "backgroundColor": "#C9D0DB",
                            "cornerRadius": "10px",
                            "paddingTop": "4px",
                            "paddingBottom": "4px",
                            "paddingStart": "4px",
                            "paddingEnd": "4px",
                            "contents": [
                              { "type": "text", "text": "{{ cell.day }}", "color": "#ffffff", "weight": "bold", "size": "xl", "align": "center" }
                            ]
                          }
                        ]
                      }{% else %}{ "type": "box", "layout": "vertical", "flex": 1, "contents": [], "margin": "3px" }{% endif %}{% unless forloop.last %},{% endunless %}{% endfor %}
                    ]
                  }{% endfor %}
                ]
              }
            ]
          }
        }{% unless forloop.last %},{% endunless %}{% endfor %}
      ]
    }
  {% endif %}
]